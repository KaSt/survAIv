# ── survaiv cloud configuration ──────────────────────────────────
#
# Copy this file to .env and fill in your values.
# All values can also be overridden at runtime via the dashboard.

# LLM provider base URL (tx402.ai, x402engine, or any OpenAI-compatible endpoint)
SURVAIV_OAI_URL=https://tx402.ai/v1

# Model ID (provider-specific, e.g. "deepseek/deepseek-v3.2")
SURVAIV_OAI_MODEL=deepseek/deepseek-v3.2

# API key for non-x402 providers (leave empty for x402 providers)
SURVAIV_API_KEY=

# Ethereum private key (64 hex chars, no 0x prefix) — used for x402 payments and CLOB auth
SURVAIV_WALLET_KEY=

# Polygon RPC endpoint for balance queries
SURVAIV_POLYGON_RPC=https://polygon-rpc.com

# Polymarket CLOB base URL
SURVAIV_CLOB_URL=https://clob.polymarket.com

# Paper trading mode (true = no real trades)
SURVAIV_PAPER_ONLY=true

# Agent loop interval in seconds
SURVAIV_LOOP_SECONDS=900

# Starting bankroll in USDC
SURVAIV_STARTING_BANKROLL=25.0

# Reserve floor — agent stops trading when equity <= reserve
SURVAIV_RESERVE=5.0

# Maximum simultaneous open positions
SURVAIV_MAX_POSITIONS=3

# Number of markets to fetch per cycle
SURVAIV_MARKET_LIMIT=10

# Maximum daily loss before agent pauses (USDC)
SURVAIV_DAILY_LOSS_LIMIT=5.0

# Dashboard HTTP port (Heroku sets PORT automatically)
SURVAIV_PORT=8080

# SQLite database path
SURVAIV_DB_PATH=survaiv.db

# ── Heroku detection ──
# DYNO is set automatically by Heroku — do not set manually.
# When present, the agent runs in headless mode (HTTP dashboard only, no TUI).
